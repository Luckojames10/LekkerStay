// This is the Prisma schema for the LekkerStay application\n\n// Define data models\nmodel User {\n  id          Int       @id @default(autoincrement())\n  username    String    @unique\n  email       String    @unique\n  password    String\n  listings    Listing[]\n  bookings     Booking[]\n  reviews     Review[]\n  messages    Message[]\n}\n\nmodel Listing {\n  id            Int       @id @default(autoincrement())\n  title         String\n  description   String\n  price         Float\n  availableFrom  DateTime\n  availableTo    DateTime\n  userId       Int\n  user         User      @relation(fields: [userId], references: [id])\n  bookings     Booking[]\n  reviews     Review[]\n}\n\nmodel Booking {\n  id          Int        @id @default(autoincrement())\n  listingId   Int\n  userId      Int\n  checkIn     DateTime\n  checkOut    DateTime\n  status       BookingStatus\n  listing     Listing   @relation(fields: [listingId], references: [id])\n  user        User      @relation(fields: [userId], references: [id])\n}\n\nmodel Payment {\n  id          Int       @id @default(autoincrement())\n  bookingId   Int\n  amount      Float\n  status      PaymentStatus\n  booking     Booking     @relation(fields: [bookingId], references: [id])\n}\n\nmodel Message {\n  id          Int     @id @default(autoincrement())\n  content      String\n  senderId    Int\n  receiverId  Int\n  createdAt   DateTime  @default(now())\n  sender      User      @relation(fields: [senderId], references: [id])\n  receiver    User      @relation(fields: [receiverId], references: [id])\n}\n\nmodel Review {\n  id          Int     @id @default(autoincrement())\n  content      String\n  rating       Int       @range(1, 5)\n  listingId   Int\n  userId      Int\n  listing     Listing   @relation(fields: [listingId], references: [id])\n  user        User      @relation(fields: [userId], references: [id])\n}\n\n// Define enums\nenum BookingStatus {\n  PENDING\n  CONFIRMED\n  CANCELED\n}\n\nenum PaymentStatus {\n  PENDING\n  COMPLETED\n  FAILED\n}